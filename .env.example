# 사이트 base URL — sitemap·robots·메타 (없으면 https://medplace.kr fallback)
NEXT_PUBLIC_BASE_URL="https://medplace.kr"

# Firebase Web (Client) — NEXT_PUBLIC_ 프리픽스 필수 (브라우저 노출)
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID=""
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# Firebase Admin (Server only — 절대 NEXT_PUBLIC_ 붙이지 말 것)
FIREBASE_ADMIN_PROJECT_ID=""
FIREBASE_ADMIN_CLIENT_EMAIL=""
FIREBASE_ADMIN_PRIVATE_KEY=""           # \n은 그대로 두고 코드에서 replace

# next-firebase-auth-edge
NEXT_PUBLIC_FIREBASE_AUTH_COOKIE_NAME="AuthToken"
FIREBASE_AUTH_COOKIE_SIGNATURE_KEY_1=""  # 32 bytes 이상, openssl rand -base64 32
FIREBASE_AUTH_COOKIE_SIGNATURE_KEY_2=""  # 키 로테이션용

# OAuth — Google은 Firebase Console에서 자동, 카카오는 Phase 2+ Custom Token 방식
KAKAO_REST_API_KEY=""                    # Phase 2+
KAKAO_CLIENT_SECRET=""                   # Phase 2+

# PortOne V2 — Phase β-1 실결제 통합 (prepare → confirm 모델).
# Server-only 환경변수:
#   PORTONE_API_SECRET 미설정 시 cancelPayment/preRegister/getPayment 는 mock 응답
#   PORTONE_WEBHOOK_SECRET 미설정 시 webhook 은 fail-closed (Phase α-4) — dev 테스트 시 반드시 set
PORTONE_STORE_ID=""
PORTONE_API_SECRET=""           # server-to-server 인증
PORTONE_CHANNEL_KEY_KAKAO=""
PORTONE_CHANNEL_KEY_TOSS=""
PORTONE_WEBHOOK_SECRET=""        # HMAC-SHA256(payload, secret) → hex 검증 / Phase α-4 fail-closed

# PortOne V2 — Client (브라우저 SDK 호출용)
# NEXT_PUBLIC_PORTONE_STORE_ID 미설정 시 /checkout 은 mock 모드(createOrder 자동 PAID)로 자동 fallback
NEXT_PUBLIC_PORTONE_STORE_ID=""
NEXT_PUBLIC_PORTONE_CHANNEL_KEY_KAKAO=""
NEXT_PUBLIC_PORTONE_CHANNEL_KEY_TOSS=""

# Naver Clova OCR (사업자등록증)
NAVER_CLOVA_OCR_INVOKE_URL=""
NAVER_CLOVA_OCR_SECRET=""

# Solapi (알림톡) — Wave A: Cloud Function 에서 실 발송
SOLAPI_API_KEY=""
SOLAPI_API_SECRET=""
SOLAPI_PFID=""   # 카카오 플러스친구 ID

# Transactional 이메일 (SendGrid) — Wave A: Cloud Function 에서 실 발송
SENDGRID_API_KEY=""
EMAIL_FROM="noreply@medplace.example.com"

# Upstash Redis (Phase 2+ — 캐시·rate limiting)
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Algolia (Phase 2+ — 상품 검색)
NEXT_PUBLIC_ALGOLIA_APP_ID=""
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=""        # search-only key
ALGOLIA_ADMIN_KEY=""                     # server only

# MFDS UDI OpenAPI
MFDS_UDI_API_KEY=""
MFDS_UDI_API_ENDPOINT=""

# 국세청 사업자 진위확인
NTS_BIZINFO_API_KEY=""

# Sentry (Phase ν-2)
# SENTRY_DSN — server / edge runtime
# NEXT_PUBLIC_SENTRY_DSN — browser (NEXT_PUBLIC_ 가 없어도 client config 가 SENTRY_DSN fallback)
# Production 환경(NODE_ENV=production)에서만 init. 그 외 환경은 console.warn 만 한 번.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_AUTH_TOKEN=""

# PostHog
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST=""

# Cron Secret (Vercel Cron 또는 Cloud Scheduler 인증)
CRON_SECRET=""

# Seed user passwords (Phase 1.5-F: reseed-users-after-auth)
# 비워두면 reseed 스크립트가 자동 생성 후 .env.local에 patch
SEED_BUYER_PASSWORD=""
SEED_VENDOR_PASSWORD=""
SEED_ADMIN_PASSWORD=""

# Phase α-2 — 디자인 미리보기용 권한 우회 플래그.
# "true" 일 때만 dev 환경에서 role 가드 / 비로그인 접근 우회 (개발자 본인 로컬만).
# 절대 production / staging 에서 활성화 금지.
# 적용 위치: src/server/api/trpc.ts, src/proxy.ts, src/app/(vendor)/seller/(approved)/layout.tsx
ENABLE_PREVIEW_BYPASS=""
