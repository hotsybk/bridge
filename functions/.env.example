# Cloud Functions 환경변수 (functions/.env 또는 firebase functions:secrets:set)
#
# 운영 환경에서는 secrets manager 권장:
#   firebase functions:secrets:set SOLAPI_API_KEY
#   firebase functions:secrets:set SOLAPI_API_SECRET
#   firebase functions:secrets:set SOLAPI_PFID
#   firebase functions:secrets:set SENDGRID_API_KEY
#
# 모든 키 미설정 시 mock fallback 으로 동작 (개발 환경 보호).
# 자동 배포 금지 — CLAUDE.md §1.1.

# Solapi 알림톡
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_PFID=

# Transactional 이메일 (SendGrid)
SENDGRID_API_KEY=
EMAIL_FROM=noreply@medplace.example.com

# Naver Clova OCR (사업자등록증)
CLOVA_OCR_INVOKE_URL=
CLOVA_OCR_SECRET=

# 국세청 사업자 진위확인
NTS_API_KEY=

# PortOne V2 (Phase 2)
PORTONE_API_SECRET=
PORTONE_WEBHOOK_SECRET=

# Algolia (Wave Z — 검색 통합)
# 미설정 시 트리거·callable 모두 mock 모드로 동작 (실제 외부 호출 없음).
ALGOLIA_APP_ID=
ALGOLIA_ADMIN_KEY=
ALGOLIA_INDEX_NAME=products
